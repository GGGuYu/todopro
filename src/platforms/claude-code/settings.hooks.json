{
  "_comment": "TodoPro Claude Code hooks 配置片段。init 程序会把 hooks 字段 merge 进用户的 .claude/settings.json。此文件本身不是直接使用的 settings.json,而是 merge 源。",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/src/platforms/claude-code/stop-hook.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TodoPro",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/src/platforms/claude-code/post-tool-use.js\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/src/platforms/claude-code/post-tool-use.js\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/src/platforms/claude-code/subagent-stop.js\""
          }
        ]
      }
    ]
  }
}
